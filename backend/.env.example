# AEROVHYN — Environment Configuration
# Copy this to .env and fill in the required values.
# Never commit .env to version control.

# -------------------------------------------------------
# REQUIRED — Server will refuse to start without these
# -------------------------------------------------------

# JWT signing secret. Generate with: openssl rand -hex 32
AEROVHYN_JWT_SECRET=your_64_char_random_hex_here

# -------------------------------------------------------
# DATABASE
# -------------------------------------------------------

# PostgreSQL connection string (production).
# If unset, the server falls back to SQLite via AEROVHYN_DB_PATH.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# SQLite database path (local dev only).
AEROVHYN_DB_PATH=aerovhyn.db

# -------------------------------------------------------
# REDIS (cross-worker cache)
# -------------------------------------------------------

# Redis connection string. If unset, uses in-process memory cache.
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=

# -------------------------------------------------------
# CORS
# -------------------------------------------------------

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# -------------------------------------------------------
# LOGGING
# -------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: "json" (structured, for Loki/Datadog) | "text" (local dev)
LOG_FORMAT=json

# -------------------------------------------------------
# NOTIFICATIONS — Twilio SMS
# -------------------------------------------------------

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# -------------------------------------------------------
# NOTIFICATIONS — Firebase Cloud Messaging (mobile push)
# -------------------------------------------------------

FCM_SERVER_KEY=

# -------------------------------------------------------
# OBSERVABILITY — Sentry
# -------------------------------------------------------

# Sentry DSN for exception tracking (leave blank to disable)
SENTRY_DSN=
